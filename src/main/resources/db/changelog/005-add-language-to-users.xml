<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="005-add-language-to-users" author="a.zakharenkov" runInTransaction="true">

        <dropNotNullConstraint tableName="users" columnName="timezone" columnDataType="VARCHAR(50)"/>

        <addColumn tableName="users">
            <column name="language" type="VARCHAR(2)"/>
        </addColumn>

        <rollback>
            <addNotNullConstraint tableName="users" columnName="timezone"
                                  columnDataType="VARCHAR(50)"/>
            <dropColumn tableName="users" columnName="language"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
