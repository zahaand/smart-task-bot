<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="006-add-cascade-to-tasks" author="a.zakharenkov">

        <dropForeignKeyConstraint baseTableName="tasks" constraintName="fk_tasks_users"/>

        <addForeignKeyConstraint baseTableName="tasks"
                                 baseColumnNames="telegram_user_id"
                                 constraintName="fk_tasks_users_cascade"
                                 referencedTableName="users"
                                 referencedColumnNames="telegram_user_id"
                                 onDelete="CASCADE"/>

        <rollback>
            <dropForeignKeyConstraint baseTableName="tasks"
                                      constraintName="fk_tasks_users_cascade"/>

            <addForeignKeyConstraint baseTableName="tasks"
                                     baseColumnNames="telegram_user_id"
                                     constraintName="fk_tasks_users"
                                     referencedTableName="users"
                                     referencedColumnNames="telegram_user_id"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
